---
const pathname = new URL(Astro.request.url).pathname;
console.log(pathname);
---

<aside class="aside">
  <nav class="aside__wrapper">
    <ul class="aside__topics">
      <li class="aside__topic">
        <div class="aside__topic-title">
          <a href="/">Getting Started</a>
        </div>

        <ul class="aside__topic-items">
          <li class="aside__topic-item">
            <a href="/" class={pathname === "/" ? "active" : ""}>
              What is Fluffle?
            </a>
          </li>

          <li class="aside__topic-item">
            <a
              href="/introduction/installation"
              class={pathname === "/introduction/installation" ? "active" : ""}
            >
              Installation setup
            </a>
          </li>
        </ul>
      </li>

      <li class="aside__topic">
        <div class="aside__topic-title">
          <a href="/features/stylesheet-api">Features</a>
        </div>

        <ul class="aside__topic-items">
          <li class="aside__topic-item">
            <a
              href="/features/stylesheet-api"
              class={pathname === "/features/stylesheet-api" ? "active" : ""}
            >
              StyleSheet API
            </a>
          </li>

          <li class="aside__topic-item">
            <a
              class={pathname === "/features/nesting" ? "active" : ""}
              href="/features/nesting"
            >
              Nesting
            </a>
          </li>

          <li class="aside__topic-item">
            <a
              class={pathname === "/features/shorthands" ? "active" : ""}
              href="/features/shorthands"
            >
              Shorthand properties
            </a>
          </li>

          <li class="aside__topic-item">
            <a
              class={pathname === "/features/mixins" ? "active" : ""}
              href="/features/mixins"
            >
              Mixins
            </a>
          </li>
        </ul>
      </li>

      <li class="aside__topic">
        <div class="aside__topic-title">
          <a href="/contributing/issues">Contributing</a>
        </div>

        <ul class="aside__topic-items">
          <li class="aside__topic-item">
            <a
              class={pathname === "/contributing/issues" ? "active" : ""}
              href="/contributing/issues">Issues and bugs</a
            >
          </li>

          <li class="aside__topic-item">
            <a
              class={pathname === "/contributing/pull-requests" ? "active" : ""}
              href="/contributing/pull-requests"
            >
              Pull requests
            </a>
          </li>

          <li class="aside__topic-item">
            <a
              class={pathname === "/contributing/donate" ? "active" : ""}
              href="/contributing/donate"
            >
              Donate
            </a>
          </li>
        </ul>
      </li>
    </ul>
  </nav>
</aside>
