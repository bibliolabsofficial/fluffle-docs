---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header";
import MainWrapper from "../../layouts/MainWrapper.astro";
import Aside from "../../components/Aside.astro";
import Content from "../../layouts/Content.astro";
import Code from '../../components/Code.astro';
import NavButton from '../../components/NavButton.astro';
import Footer from "../../components/Footer";
---

<Layout title="Mixins | Fluffle">
  <Header />

  <MainWrapper>
    <Aside />

    <main>
      <Content title="Mixins">
        <p>
          Fluffle supports reusable style fragments through <strong>mixins</strong>.
          Mixins allow you to define a set of styles once and reuse them across your
          StyleSheet using the <code>$include</code> property.
        </p>

        <h3>Defining a mixin</h3>
        <p>
          Mixins are plain objects that group reusable style properties.
        </p>

        <Code
          lang="ts"
          code={`
const center = {
  justifyContent: 'center',
  alignItems: 'center',
};
`}
        />

        <h3>Using a mixin</h3>
        <p>
          Use the <code>$include</code> property to apply a mixin inside a style.
        </p>

        <Code
          lang="ts"
          code={`
const styles = StyleSheet.create({
  container: {
    $include: center,
    height: '100%',
  },
});
`}
        />

        <h3>Combining multiple mixins</h3>
        <p>
          You can include multiple mixins by passing an array.
        </p>

        <Code
          lang="ts"
          code={`
const center = {
  justifyContent: 'center',
  alignItems: 'center',
};

const fullSize = {
  width: '100%',
  height: '100%',
};

const styles = StyleSheet.create({
  container: {
    $include: [center, fullSize],
  },
});
`}
        />

        <h3>Overriding mixin values</h3>
        <p>
          Properties defined after <code>$include</code> will override mixin values.
        </p>

        <Code
          lang="ts"
          code={`
const styles = StyleSheet.create({
  container: {
    $include: center,
    justifyContent: 'flex-start', // overrides mixin
  },
});
`}
        />

        <h3>Best practices</h3>
        <ul>
          <li>Keep mixins small and focused.</li>
          <li>Use descriptive names for reuse.</li>
          <li>Avoid deeply nested or overly complex mixins.</li>
        </ul>

        <NavButton
          prev={{ title: 'Features: Shorthand properties', href: '/features/shorthands' }}
          next={{ title: 'Contributing: Issues and Bugs', href: '/contributing/issues' }}
        />
      </Content>
    </main>
  </MainWrapper>

  <Footer />
</Layout>
