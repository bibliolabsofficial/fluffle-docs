---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header";
import MainWrapper from "../../layouts/MainWrapper.astro";
import Aside from "../../components/Aside.astro";
import Content from "../../layouts/Content.astro";
import Code from "../../components/Code.astro";
import Footer from "../../components/Footer";
import NavButton from '../../components/NavButton.astro';
---

<Layout title="StyleSheet API | Fluffle">
  <Header />

  <MainWrapper>
    <Aside />

    <main>
      <Content title="StyleSheet API">
         <p>
          The <strong>StyleSheet API</strong> works similarly to the <a
            href="https://reactnative.dev/docs/stylesheet"
            target="_blank" rel="noopener noreferrer">React Native StyleSheet API</a
          >, but with added support for advanced features like
          <strong>nested styles</strong>, <strong>mixins</strong>, and more <strong>powerful shorthand properties</strong>.
        </p>

        <p>
          This allows you to structure styles in a more intuitive and
          maintainable way, especially for complex components.
        </p>

        <h3>Creating a StyleSheet object</h3>
        <p>
          Import <code>StyleSheet</code> from <code>@bibliolab/react-native-fluffle</code> and use its own <code>create</code> method to define your styles.
        </p>

        <Code code={
`import { StyleSheet } from '@bibliolab/react-native-fluffle';

const styles = create({
  card: {
    padding: '1rem',
    backgroundColor: '#fff',
    borderRadius: '0.75rem',

    header: {
      flexDirection: 'row',
      alignItems: 'center',
      marginBottom: '0.75rem',

      avatar: {
        width: '3rem',
        height: '3rem',
        borderRadius: '1.5rem',
        marginRight: '0.75rem',
      },

      name: {
        fontSize: '1.125rem',
        fontWeight: '700',
        color: '#111',
      },

      username: {
        fontSize: '0.875rem',
        color: '#666',
      },
    },

    actions: {
      flexDirection: 'row',
      marginTop: '1rem',

      button: {
        paddingVertical: '0.625rem',
        paddingHorizontal: '0.875rem',
        borderRadius: '0.5rem',
        marginRight: '0.5rem',

        text: { fontWeight: '600' },

        primary: {
          backgroundColor: '#2563eb',
          text: { color: '#fff' },
        },

        secondary: {
          backgroundColor: '#e5e7eb',
          text: { color: '#111' },
        },
      },
    },
  },
});`}
        />

        <h3>Using styles</h3>
        <p>
          Apply styles using the returned object. Each key corresponds to a style definition.
        </p>

        <Code
          lang="tsx"
          code={
`<View style={styles.card}>
  <View style={styles.card.header}>
    <Image
      source={{ uri: user.avatar }}
      style={styles.card.header.avatar}
    />

    <View>
      <Text style={styles.card.header.info.name}>
        {user.name}
      </Text>

      <Text style={styles.card.header.info.username}>
        @{user.username}
      </Text>
    </View>
  </View>

  <View style={styles.card.actions}>
    <Pressable
      style={[
        styles.card.actions.button,
        styles.card.actions.button.primary,
      ]}
    >
      <Text
        style={[
          styles.card.actions.button.text,
          styles.card.actions.button.primary.text,
        ]}
      >
        Follow
      </Text>
    </Pressable>

    <Pressable
      style={[
        styles.card.actions.button,
        styles.card.actions.button.secondary,
      ]}
    >
      <Text
        style={[
          styles.card.actions.button.text,
          styles.card.actions.button.secondary.text,
        ]}
      >
        Message
      </Text>
    </Pressable>
  </View>
</View>`
  }
        />

        <h3>Best practices</h3>
        <ul>
          <li>Keep styles small and reusable.</li>
          <li>Use descriptive names for style keys.</li>
          <li>Avoid empty style objects.</li>
          <li>Group related styles together.</li>
        </ul>

        <NavButton
          prev={{ title: 'Getting started | Installation setup', href: '/' }}
          next={{ title: 'Features | Typing & Intellisense', href: '/features/typing-intellisense' }}
        />
      </Content>
    </main>
  </MainWrapper>

  <Footer />
</Layout>
