---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header";
import MainWrapper from "../../layouts/MainWrapper.astro";
import Aside from "../../components/Aside.astro";
import Content from "../../layouts/Content.astro";
import Code from '../../components/Code.astro';
import NavButton from '../../components/NavButton.astro';
import Footer from "../../components/Footer";
---

<Layout title="Installation | Fluffle">
  <Header />

  <MainWrapper>
    <Aside />

    <main>
      <Content title="Installation setup">
             <p>
          Install <strong>Fluffle</strong> using your preferred package manager.
        </p>

        <h3>Using npm</h3>
        <Code
          theme='none'
          lang="bash"
          code={`npm install @bibliolabs/react-native-fluffle`}
        />

        <h3>Using Yarn</h3>
        <Code
          theme='none'
          lang="bash"
          code={`yarn add @bibliolabs/react-native-fluffle`}
        />

        <h3>Using pnpm</h3>
        <Code
          theme='none'
          lang="bash"
          code={`pnpm add @bibliolabs/react-native-fluffle`}
        />

        <h3>Next steps</h3>
        <p>
          After installing, you can start using the <code>StyleSheet</code> API
          to create structured and reusable styles in your components.
        </p>

        <NavButton
          prev={{ title: 'Getting started | What is Fluffle?', href: '/' }}
          next={{ title: 'Features | StyleSheet API', href: '/features/stylesheet-api' }}
        />
      </Content>
    </main>
  </MainWrapper>

  <Footer />
</Layout>
