---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header";
import MainWrapper from "../../layouts/MainWrapper.astro";
import Aside from "../../components/Aside.astro";
import Content from "../../layouts/Content.astro";
import NavButton from '../../components/NavButton.astro';
import Footer from "../../components/Footer";
---

<Layout title="Contributing: Issues and Bugs | Fluffle">
  <Header />

  <MainWrapper>
    <Aside />

    <main>
      <Content title="Issues and Bugs">
        <p>
          Found a bug or something not working as expected? Great — reporting issues is one of the most valuable ways to contribute.
        </p>

        <h3>Before opening an issue</h3>
        <ul>
          <li>Make sure the issue hasn’t already been reported.</li>
          <li>Check the documentation to confirm expected behavior.</li>
          <li>Try reproducing the issue with a minimal example.</li>
        </ul>

        <h3>When creating an issue</h3>
        <ul>
          <li>Provide a clear and descriptive title.</li>
          <li>Explain what you expected to happen.</li>
          <li>Describe what actually happened.</li>
          <li>Include steps to reproduce the problem.</li>
          <li>Attach screenshots or logs if relevant.</li>
        </ul>

        <h3>Bug reports</h3>
        <p>
          The more detail you provide, the easier it is to fix the issue. If possible, include a minimal reproduction repository.
        </p>

        <h3>Feature requests</h3>
        <p>
          Suggestions are welcome! Explain the problem you're trying to solve and why it would be useful.
        </p>

        <NavButton
          prev={{ title: 'Features | Mixins', href: '/features/mixins' }}
          next={{ title: 'Contributing | Pull requests', href: '/contributing/pull-requests' }}
        />
      </Content>
    </main>
  </MainWrapper>

  <Footer />
</Layout>
