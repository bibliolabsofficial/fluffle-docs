---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header";
import MainWrapper from "../layouts/MainWrapper.astro";
import Aside from "../components/Aside.astro";
import Content from "../layouts/Content.astro";
import NavButton from '../components/NavButton.astro';
import Footer from "../components/Footer";
---

<Layout title="404 Error | Fluffle">
  <Header />

  <MainWrapper>
    <Aside />

    <main>
      <Content title="Page Not Found">
        <p>The page you tried to navigate to couldn't be found. Check your URL and try again.</p>

        <NavButton
          prev={{ title: 'Getting started | What is Fluffle', href: '/' }}
        />
      </Content>
    </main>
  </MainWrapper>

  <Footer />
</Layout>
